<nav class="bg-gray-800 border-gray-200 px-2 sm:px-4 py-2.5">
  <div class="container flex flex-wrap justify-between items-center mx-auto">
    <%= link_to root_path, class: "text-white text-xl font-bold tracking-wide" do %>
      連絡ノート
    <% end %>

    <div class="w-full md:block md:w-auto">
      <ul class="flex flex-col mt-4 md:flex-row md:space-x-6 md:mt-0 md:text-sm md:font-medium items-center">

        <% if user_signed_in? %>
          <li>
            <span class="text-xs bg-gray-700 text-white px-3 py-1 rounded-full">
              🏬 <%= current_user.store.name %>
            </span>
          </li>

          <li>
            <%= link_to "共有一覧", posts_path, class: "text-gray-200 hover:text-white" %>
          </li>

          <li>
            <%= link_to "投稿", new_post_path, class: "text-gray-200 hover:text-white" %>
          </li>

          <li>
            <%= link_to "マイページ", user_path(current_user), class: "text-gray-200 hover:text-white" %>
          </li>

          <li>
            <%= button_to "ログアウト", destroy_user_session_path,
              method: :delete,
              class: "text-gray-200 hover:text-white bg-transparent border-0" %>
          </li>

        <% else %>
          <li>
            <%= link_to "新規登録", new_user_registration_path, class: "text-gray-200 hover:text-white" %>
          </li>

          <li>
            <%= link_to "ログイン", new_user_session_path, class: "text-gray-200 hover:text-white" %>
          </li>
        <% end %>

      </ul>
    </div>
