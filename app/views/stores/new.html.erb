<div class="max-w-lg mx-auto mt-10 bg-white p-6 rounded-2xl shadow-sm">
  <h1 class="text-xl font-bold text-gray-800 mb-6">
    店舗を作成する
  </h1>

  <p class="text-sm text-gray-500 mb-6">
    最初に店舗を作成し、スタッフに店舗コードを共有してください。
  </p>

  <%= form_with model: @store, local: true do |f| %>
    <div class="mb-4">
      <%= f.label :name, "店舗名", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :name,
        class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="mb-4">
      <%= f.label :store_code, "店舗コード", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :store_code,
        placeholder: "例: shibuya",
        class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      <p class="text-xs text-gray-400 mt-1">
        他のスタッフが参加する際に使用します
      </p>
    </div>

    <div class="mb-6">
      <%= f.label :email, "管理用メール（任意）", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.email_field :email,
        class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <%= f.submit "店舗を作成する",
      class: "w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition" %>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to "すでに店舗がある場合はこちら", store_join_path,
      class: "text-sm text-indigo-600 hover:underline" %>
  </div>
</div>
