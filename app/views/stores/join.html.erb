<div class="max-w-lg mx-auto mt-10 bg-white p-6 rounded-2xl shadow-sm">
  <h1 class="text-xl font-bold text-gray-800 mb-6">
    店舗に参加する
  </h1>

  <p class="text-sm text-gray-500 mb-6">
    店舗コードを入力して、既存の店舗に参加できます。
  </p>

  <%= form_with url: store_join_path, method: :post, local: true do |f| %>
    <div class="mb-6">
      <%= f.label :store_code, "店舗コード", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :store_code,
        placeholder: "例: shibuya",
        class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <%= f.submit "参加する",
      class: "w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition" %>
  <% end %>

  <div class="mt-6 text-center">
    <%= link_to "新しく店舗を作成する", new_store_path,
      class: "text-sm text-indigo-600 hover:underline" %>
  </div>
</div>
