<div class="max-w-2xl mx-auto mt-10 bg-white p-6 rounded-2xl shadow-sm">
  <h1 class="text-xl font-bold text-gray-800 mb-6">店舗設定</h1>

  <div class="mb-6 rounded-xl bg-indigo-50 border border-indigo-100 px-4 py-3">
    <p class="text-sm text-gray-600">現在所属している店舗</p>
    <p class="mt-1 font-semibold text-indigo-700">
      🏬 <%= current_user.store.name %>
    </p>
  </div>

  <%= form_with scope: :store_membership, url: store_membership_path, method: :patch, local: true do |f| %>
    <div class="mb-6">
      <%= f.label :store_code, "店舗コード", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :store_code,
        value: params.dig(:store_membership, :store_code),
        required: true,
        class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500",
        placeholder: "店舗コードを入力してください" %>
    </div>

    <p class="text-sm text-gray-500 mb-6">
      店舗を変更しても、これまでに投稿した共有は元の店舗に残ります。
    </p>

    <%= f.submit "店舗に参加する",
      class: "w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition" %>
  <% end %>
</div>
