<%= form_with model: post, local: true do |f| %>
  <% if post.errors.any? %>
    <div class="mb-6 rounded-md bg-red-50 p-4 border border-red-200">
      <h2 class="text-sm font-medium text-red-800 mb-2">
        入力内容を確認してください
      </h2>
      <ul class="text-sm text-red-700 list-disc pl-5">
        <% post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :title, "タイトル", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title,
      class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-4">
    <%= f.label :post_type, "投稿タイプ", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.select :post_type,
      [["連絡事項", "notice"], ["入荷情報", "arrival"], ["クレーム対応", "claim"], ["接客メモ", "customer_service"]],
      {},
      class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-6">
    <%= f.label :content, "内容", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_area :content, rows: 8,
      class: "w-full border border-gray-300 rounded-md px-3 py-2 focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div class="mb-6">
    <label class="flex cursor-pointer items-start gap-3 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 hover:bg-red-100/60 transition">
        <%= f.check_box :important,
        class: "mt-1 h-4 w-4 rounded border-gray-300 text-red-500 focus:ring-red-500" %>

        <div>
        <p class="text-sm font-semibold text-red-700">
            重要な共有として投稿する
        </p>
        <p class="text-xs text-red-600 mt-1">
            見落としを防ぎたい連絡にマークを付けます
        </p>
        </div>
    </label>
  </div>

  <%= f.submit submit_label,
    class: "w-full bg-indigo-600 text-white py-2 rounded-md hover:bg-indigo-700 transition" %>
<% end %>
