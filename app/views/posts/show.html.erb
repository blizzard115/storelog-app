<div class="space-y-6 w-3/4 max-w-3xl mx-auto">
  <h1 class="text-xl font-bold text-gray-700">共有内容の詳細</h1>

  <div class="bg-white p-6 shadow rounded">
    <% if @post.important? %>
      <div class="mb-4 inline-flex items-center gap-2 rounded-xl bg-red-50 px-3 py-2 text-sm font-semibold text-red-600 ring-1 ring-inset ring-red-200">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-11a1 1 0 10-2 0v4a1 1 0 102 0V7zm-1 8a1.25 1.25 0 100-2.5A1.25 1.25 0 0010 15z" clip-rule="evenodd" />
        </svg>
        重要な共有です
      </div>
    <% end %>
    <div class="flex items-start justify-between w-full border-b border-gray-200 pb-6">
      <div class="pl-3">
        <h2 class="text-lg font-medium leading-5 text-gray-800">
          <%= @post.title %>
        </h2>

        <p class="text-sm leading-normal pt-2 text-gray-500">
          by <%= link_to @post.user.nickname, user_path(@post.user), class: "hover:text-indigo-600 hover:font-bold" %>
        </p>

        <div class="flex gap-2 pt-3 flex-wrap">
          <span class="inline-block text-xs font-medium px-3 py-1 rounded-full
            <%= case @post.post_type
                when "notice" then "bg-blue-100 text-blue-700"
                when "arrival" then "bg-green-100 text-green-700"
                when "claim" then "bg-red-100 text-red-700"
                when "customer_service" then "bg-purple-100 text-purple-700"
                end %>">
            <%= @post.post_type_label %>
          </span>
        </div>
      </div>

      <% if user_signed_in? && @post.user == current_user %>
        <div class="flex gap-2">
          <%= link_to "編集",
            edit_post_path(@post),
            class: "text-sm bg-white hover:bg-gray-100 text-gray-700 py-1 px-3 border border-gray-300 rounded" %>

          <%= button_to "削除",
            post_path(@post),
            method: :delete,
            class: "text-sm bg-transparent hover:bg-blue-500 text-blue-700 hover:text-white py-1 px-3 border border-blue-500 hover:border-transparent rounded hover:cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="px-2">
      <p class="text-sm leading-relaxed py-4 text-gray-600 whitespace-pre-wrap"><%= @post.content %></p>
    </div>

    <div class="border-t border-gray-200 pt-4 mt-4">
      <% if user_signed_in? && @post.user != current_user %>
        <% unless @post.read_users.include?(current_user) %>
          <%= button_to "確認しました",
            post_read_path(@post),
            method: :post,
            class: "bg-green-500 text-white px-4 py-2 rounded hover:bg-green-600 transition" %>
        <% else %>
          <p class="text-green-600 font-medium">✓ 確認済み</p>
        <% end %>
      <% end %>

      <% if @post.user == current_user %>
        <p class="text-sm text-gray-500">この投稿はあなたが作成しました</p>
      <% end %>

      <p class="text-sm text-gray-500 mt-3">
        <%= @post.read_users.where.not(id: @post.user_id).count %>人が確認しました
      </p>
    </div>

    <% confirmed_users = @post.read_users.where.not(id: @post.user_id) %>

      <% if confirmed_users.any? %>
        <div class="mt-3">
          <p class="text-sm font-medium text-gray-700">確認済みスタッフ</p>
          <div class="flex flex-wrap gap-2 mt-2">
            <% confirmed_users.each do |user| %>
              <span class="inline-block text-xs px-3 py-1 rounded-full bg-gray-100 text-gray-700">
                <%= user.nickname %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

    <% if @unread_users.any? %>
      <div class="mt-4">
        <p class="text-sm font-medium text-gray-700">未確認スタッフ</p>
        <div class="flex flex-wrap gap-2 mt-2">
          <% @unread_users.each do |user| %>
            <span class="inline-block text-xs px-3 py-1 rounded-full bg-red-100 text-red-700">
              <%= user.nickname %>
            </span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>