<div class="space-y-6 w-3/4 max-w-3xl mx-auto">
  <h1 class="text-xl font-bold text-gray-900">
    <%= @user.nickname %>さんの共有一覧
  </h1>

  <%= form_with url: user_path(@user), method: :get, local: true, class: "mb-6" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :keyword,
        value: params[:keyword],
        placeholder: "タイトルや内容で検索",
        class: "flex-1 px-4 py-2 border border-gray-300 rounded-md focus:ring-indigo-500 focus:border-indigo-500" %>

      <%= f.hidden_field :post_type, value: params[:post_type] %>
      <%= f.hidden_field :read_status, value: params[:read_status] %>

      <%= f.submit "検索",
        class: "px-4 py-2 bg-indigo-600 text-white rounded-md hover:bg-indigo-700 transition" %>
    </div>
  <% end %>

  <div class="mb-2">
    <p class="text-sm font-medium text-gray-700">確認状況</p>
  </div>

  <div class="flex gap-2 mb-4">
    <%= link_to "すべて",
      user_path(@user, keyword: params[:keyword], post_type: params[:post_type]),
      class: "px-3 py-1 rounded #{params[:read_status].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-800'}" %>

    <%= link_to "未読のみ",
      user_path(@user, keyword: params[:keyword], post_type: params[:post_type], read_status: "unread"),
      class: "px-3 py-1 rounded #{params[:read_status] == 'unread' ? 'bg-red-500 text-white' : 'bg-red-100 text-red-700'}" %>
  </div>

  <div class="mb-2">
    <p class="text-sm font-medium text-gray-700">投稿タイプ</p>
  </div>

  <div class="flex gap-2 mb-6 flex-wrap">
    <%= link_to "すべて",
      user_path(@user, keyword: params[:keyword], read_status: params[:read_status]),
      class: "px-3 py-1 rounded #{params[:post_type].blank? ? 'bg-indigo-600 text-white' : 'bg-gray-200 text-gray-800'}" %>

    <%= link_to "連絡事項",
      user_path(@user, post_type: "notice", keyword: params[:keyword], read_status: params[:read_status]),
      class: "px-3 py-1 rounded #{params[:post_type] == 'notice' ? 'bg-blue-500 text-white' : 'bg-blue-100 text-blue-700'}" %>

    <%= link_to "入荷情報",
      user_path(@user, post_type: "arrival", keyword: params[:keyword], read_status: params[:read_status]),
      class: "px-3 py-1 rounded #{params[:post_type] == 'arrival' ? 'bg-green-500 text-white' : 'bg-green-100 text-green-700'}" %>

    <%= link_to "クレーム対応",
      user_path(@user, post_type: "claim", keyword: params[:keyword], read_status: params[:read_status]),
      class: "px-3 py-1 rounded #{params[:post_type] == 'claim' ? 'bg-red-500 text-white' : 'bg-red-100 text-red-700'}" %>

    <%= link_to "接客メモ",
      user_path(@user, post_type: "customer_service", keyword: params[:keyword], read_status: params[:read_status]),
      class: "px-3 py-1 rounded #{params[:post_type] == 'customer_service' ? 'bg-purple-500 text-white' : 'bg-purple-100 text-purple-700'}" %>
  </div>

  <% if params[:keyword].present? || params[:post_type].present? || params[:read_status].present? %>
    <p class="text-sm text-gray-500 mb-2">
      条件に一致する共有が <%= @post_count %>件見つかりました
    </p>
  <% else %>
    <p class="text-gray-600">全投稿数: <%= @post_count %>件</p>
  <% end %>

  <% if @posts.empty? %>
    <div class="bg-white rounded-lg shadow-sm p-6 text-center">
      <% if params[:keyword].present? || params[:post_type].present? || params[:read_status].present? %>
        <p class="text-gray-600">条件に一致する共有はありません。</p>
      <% else %>
        <p class="text-gray-600">まだ共有はありません。</p>
      <% end %>
    </div>
  <% else %>
    <div class="space-y-6">
      <% @posts.each do |post| %>
        <div class="bg-white p-6 shadow rounded">
          <div class="flex items-center border-b border-gray-200 pb-6">
            <div class="w-full">
              <div class="flex items-center gap-2 flex-wrap">
                <p class="text-lg font-medium leading-5 text-gray-800">
                  <%= link_to post.title, post_path(post), class: "hover:text-indigo-600" %>
                </p>

                <% if user_signed_in? && post.user != current_user %>
                  <% if post.read_users.include?(current_user) %>
                    <span class="text-xs px-2 py-1 rounded-full bg-gray-200 text-gray-600">
                      既読
                    </span>
                  <% else %>
                    <span class="text-xs px-2 py-1 rounded-full bg-red-500 text-white">
                      未読
                    </span>
                  <% end %>
                <% end %>
              </div>

              <p class="text-sm leading-normal pt-2 text-gray-500">
                <%= post.created_at.strftime("%Y年%m月%d日 %H:%M") %>
              </p>

              <div class="pt-3">
                <% if post.unread_count > 0 %>
                  <span class="inline-block text-xs px-3 py-1 rounded-full bg-red-100 text-red-700">
                    未確認 <%= post.unread_count %>人
                  </span>
                <% else %>
                  <span class="inline-block text-xs px-3 py-1 rounded-full bg-green-100 text-green-700">
                    全員確認済み
                  </span>
                <% end %>
              </div>

              <div class="flex gap-2 pt-3 flex-wrap">
                <span class="inline-block text-xs font-medium px-3 py-1 rounded-full
                  <%= case post.post_type
                      when "notice" then "bg-blue-100 text-blue-700"
                      when "arrival" then "bg-green-100 text-green-700"
                      when "claim" then "bg-red-100 text-red-700"
                      when "customer_service" then "bg-purple-100 text-purple-700"
                      end %>">
                  <%= post.post_type_label %>
                </span>
              </div>
            </div>
          </div>

          <div class="px-2">
            <p class="text-sm leading-5 py-4 text-gray-600 line-clamp-3 overflow-hidden">
              <%= post.content %>
            </p>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
